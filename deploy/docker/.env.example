APP_NAME=Praina API
ENVIRONMENT=prod
API_V1_PREFIX=/api/v1

POSTGRES_DB=praina
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

FRONTEND_PORT=8080

# Optional base path for deploying behind a reverse proxy (e.g. /praina).
# Leave empty to serve from /.
BASE_PATH=

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Same-origin proxy through nginx means this can usually stay empty.
CORS_ALLOWED_ORIGINS=

TEXT_INFERENCE_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_ENABLE_THINKING=false
OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2-moe
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=16
EMBEDDING_HTTP_TIMEOUT_SECONDS=300
ASSISTANT_TEMPERATURE=0.2
ASSISTANT_HTTP_TIMEOUT_SECONDS=60
ACTION_EXTRACTION_HTTP_TIMEOUT_SECONDS=180
LOG_LEVEL=INFO

# Optional when using Codex instead of Ollama for text inference.
CODEX_MODEL=gpt-5.4
CODEX_TIMEOUT_SECONDS=120

# Optional Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Optional if you want Ollama exposed on the host too.
OLLAMA_PORT=11434

APP_NAME=Project Tracker API
ENVIRONMENT=dev
API_V1_PREFIX=/api/v1
APP_HOST=127.0.0.1
APP_PORT=8000
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_INTERNAL_PORT=5432
POSTGRES_DB=project_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Optional override. If set, this takes precedence over POSTGRES_* variables.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/project_tracker
CORS_ALLOWED_ORIGINS=
DOCUMENTS_STORAGE_PATH=storage/documents
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_ENABLE_THINKING=false
OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2-moe
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=16
EMBEDDING_HTTP_TIMEOUT_SECONDS=300
ASSISTANT_TEMPERATURE=0.2
ASSISTANT_HTTP_TIMEOUT_SECONDS=60
ACTION_EXTRACTION_HTTP_TIMEOUT_SECONDS=180
LOG_LEVEL=INFO
FIREBASE_CREDENTIALS_PATH=
FIREBASE_PROJECT_ID=
